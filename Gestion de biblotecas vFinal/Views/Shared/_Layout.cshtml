<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - CRAI - Sistema de Gestión Bibliotecaria</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark shadow-sm">
        <div class="container">
            @Html.ActionLink("CRAI - Sistema de Gestión Bibliotecaria", "Index", "Home", new { area = "" }, new { @class = "navbar-brand text-white fw-bold" })
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Alternar navegación" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                @if (User.Identity.IsAuthenticated)
                {
                    <ul class="navbar-nav flex-grow-1">
                        <li><a class="nav-link" href="@Url.Action("Index", "Libro")"><i class="bi bi-book"></i> Catálogo Bibliográfico</a></li>
                        <li><a class="nav-link" href="@Url.Action("Index", "Venta")"><i class="bi bi-journal-check"></i> Registro de Circulación</a></li>
                        @{ 
                            int badgeCount = Session["Carrito"] != null ? ((System.Collections.IList)Session["Carrito"]).Count : 0; 
                        }
                        <li>
                            <a class="nav-link" href="@Url.Action("VerCarrito", "Venta")">
                                <i class="bi bi-bookmark-check"></i> Bandeja 
                                <span class="badge rounded-pill ms-1" style="background-color: #DAA520; color: #1a252f;">@badgeCount</span>
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <span class="navbar-text me-3 text-white">
                                <i class="bi bi-person-circle"></i> Bienvenido, @Session["NombreUsuario"] (@Session["Rol"])
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm mt-1" href="@Url.Action("Salir", "Usuario")">
                                <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
                            </a>
                        </li>
                    </ul>
                }
                else
                {
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm mt-1" href="@Url.Action("Login", "Usuario")">
                                <i class="bi bi-box-arrow-in-right"></i> Iniciar Sesión
                            </a>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>
    <div class="container body-content">
        @RenderBody()
        <hr />
        <footer>
            <p>&copy; @DateTime.Now.Year - CRAI - Sistema de Gestión Bibliotecaria</p>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @{
        if (TempData["AlertMessage"] != null)
        {
            @Html.Raw(TempData["AlertMessage"])
        }
    }
</body>
</html>
