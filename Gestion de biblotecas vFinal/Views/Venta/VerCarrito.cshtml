@model Gestion_de_Biblioteca.Models.VentaViewModel

@{
    ViewBag.Title = "Bandeja de Reserva";
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="border-bottom pb-2 mt-4">
            <i class="bi bi-bookmark-check text-primary me-2"></i>@ViewBag.Title
        </h2>
    </div>
</div>

@if (Session["Carrito"] == null || !Model.LineasCarrito.Any())
{
    <div class="alert alert-info shadow-sm d-flex align-items-center" role="alert">
        <i class="bi bi-info-circle-fill me-3 fs-4"></i>
        <div>
            <strong>¡Atención!</strong> Su bandeja de reserva se encuentra vacía actualmente.
            <br />
            Puede agregar productos a la bandeja interactuando con el catálogo desde nuestra página principal.
        </div>
    </div>
    
    <div class="mt-4">
        @Html.ActionLink("Ir al Catálogo de Libros", "Index", "Libro", new { area = "" }, new { @class = "btn btn-outline-primary" })
    </div>
}
else
{
    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Código</th>
                    <th>Título</th>
                    <th class="text-end">Tasa de Gestión</th>
                    <th class="text-center">Cantidad</th>
                    <th class="text-end">Importe</th>
                    <th class="text-center">Quitar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.LineasCarrito)
                {
                    <tr>
                        <td class="fw-bold">@item.CodigoLibro</td>
                        <td>@item.Titulo</td>
                        <td class="text-end">S/ @item.Precio.ToString("0.00")</td>
                        <td class="text-center">
                            <span class="badge bg-secondary px-3 py-2 fs-6">@item.Cantidad</span>
                        </td>
                        <td class="text-end fw-semibold text-primary">S/ @item.Importe.ToString("0.00")</td>
                        <td class="text-center">
                            @using (Html.BeginForm("QuitarCarrito", "Venta", FormMethod.Post, new { @class = "m-0" }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="codigo" value="@item.CodigoLibro" />
                                <button type="submit" class="btn btn-sm btn-outline-danger shadow-sm" title="Quitar de la Bandeja">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light">
                <tr>
                    <td colspan="4" class="text-end fw-bold fs-5">TOTAL A PAGAR:</td>
                    <td class="text-end fw-bold fs-5 text-danger">S/ @Model.TotalVenta.ToString("0.00")</td>
                    <td></td>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-4">
        <div>
            @Html.ActionLink("← Seguir Explorando", "Index", "Libro", new { area = "" }, new { @class = "btn btn-outline-secondary" })
        </div>
        <div>
            <!-- Se utiliza FormMethod.Post como se enseña en laboratorios para envíos de datos seguros -->
            @using (Html.BeginForm("ProcesarVenta", "Venta", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success btn-lg shadow-sm">
                    <i class="bi bi-check-circle me-2"></i>Procesar Reserva
                </button>
            }
        </div>
    </div>
}
