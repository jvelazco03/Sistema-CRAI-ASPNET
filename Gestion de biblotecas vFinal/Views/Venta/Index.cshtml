@model IEnumerable<Dominio.Dominio.Venta>

@{
    ViewBag.Title = "Registro de Circulación";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary">🧾 Registro de Circulación</h2>
        @Html.ActionLink("➕ Nuevo Registro", "Create", null, new { @class = "btn btn-success" })
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No hay circulación registrada.
        </div>
    }
    else
    {
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th># Reserva</th>
                    <th>Libro</th>
                    <th>Cantidad</th>
                    <th>Tasa de Gestión</th>
                    <th>Total</th>
                    <th>Fecha</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.idVenta</td>
                        <td>@item.CodigoLibro</td>
                        <td>@item.Cantidad</td>
                        <td>@item.PrecioUnitario.ToString("C")</td>
                        <td>@item.Total.ToString("C")</td>
                        <td>@item.FechaVenta.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-center">
     
                            <span class="text-muted">N/A</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
